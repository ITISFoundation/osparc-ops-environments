  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": ["* 0-4 * * *"],
  "labels": ["renovate"],
  "minimumReleaseAge": "60 days",
  "dependencyDashboard": true,
  "enabledManagers": ["helmv3", "helmfile", "github-actions"],
  "helmfile": {
    "managerFilePatterns": [
      "/^charts/helmfile\\.ci\\.yaml$/"
    ]
  }
}
